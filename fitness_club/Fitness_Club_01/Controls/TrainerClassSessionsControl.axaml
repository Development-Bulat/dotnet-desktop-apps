<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Fitness_Club_01.Controls.TrainerClassSessionsControl">

    <Grid RowDefinitions="Auto,Auto,*,Auto">
        <TextBlock Grid.Row="0" Text="Занятия на месяц" FontSize="24" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,16"/>

        <Border Grid.Row="1" Background="White" CornerRadius="14" Padding="16" Margin="0,0,0,12"
                BorderBrush="#E2E8F0" BorderThickness="1">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
                <Button Grid.Column="0" Name="PrevMonthButton" Classes="secondary" Content="←" Width="44"/>
                <TextBlock Grid.Column="1" Name="MonthText" FontSize="16" FontWeight="SemiBold"
                           Foreground="#0F172A" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <Button Grid.Column="2" Name="NextMonthButton" Classes="secondary" Content="→" Width="44" Margin="8,0,0,0"/>
                <Button Grid.Column="3" Name="CancelSessionButton" Classes="danger" Content="Отменить занятие"
                        Margin="12,0,0,0" MinWidth="150"/>
                <Button Grid.Column="4" Name="RefreshButton" Classes="secondary" Content="Обновить"
                        Margin="8,0,0,0" Width="110"/>
            </Grid>
        </Border>

        <DataGrid Grid.Row="2" Name="SessionsGrid" Classes="AppDataGrid"
                  AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="№" Binding="{Binding Number}" Width="60"/>
                <DataGridTextColumn Header="Дата" Binding="{Binding ClassDate}" Width="110"/>
                <DataGridTextColumn Header="Время" Binding="{Binding ClassTime}" Width="70"/>
                <DataGridTextColumn Header="Занятие" Binding="{Binding ClassName}" Width="180"/>
                <DataGridTextColumn Header="Зал" Binding="{Binding HallName}" Width="140"/>
                <DataGridTextColumn Header="Записано" Binding="{Binding BookedCount}" Width="100"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="*" MinWidth="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="3" Name="StatusText" Margin="0,10,0,0" Foreground="#64748B" FontSize="12"/>
    </Grid>
</UserControl>
