<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Fitness_Club_01.Controls.ReferencesControl">

    <Grid RowDefinitions="Auto,*">
        <TextBlock Grid.Row="0" Text="Справочники" FontSize="24" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,16"/>

        <TabControl Grid.Row="1">
            <TabItem Header="Залы">
                <Grid RowDefinitions="Auto,*">
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
                        <Button Name="HallAddBtn" Classes="primary" Content="Добавить" Width="110"/>
                        <Button Name="HallEditBtn" Classes="secondary" Content="Изменить" Width="110"/>
                        <Button Name="HallDeleteBtn" Classes="danger" Content="Удалить" Width="100"/>
                    </StackPanel>
                    <DataGrid Grid.Row="1" Name="HallsGrid" Classes="AppDataGrid" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Вместимость" Binding="{Binding Extra}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            <TabItem Header="Тарифы">
                <Grid RowDefinitions="Auto,*">
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
                        <Button Name="TypeAddBtn" Classes="primary" Content="Добавить" Width="110"/>
                        <Button Name="TypeEditBtn" Classes="secondary" Content="Изменить" Width="110"/>
                        <Button Name="TypeDeleteBtn" Classes="danger" Content="Удалить" Width="100"/>
                    </StackPanel>
                    <DataGrid Grid.Row="1" Name="TypesGrid" Classes="AppDataGrid" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Тариф" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Параметры" Binding="{Binding Extra}" Width="220"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            <TabItem Header="Специализации">
                <Grid RowDefinitions="Auto,*">
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
                        <Button Name="SpecAddBtn" Classes="primary" Content="Добавить" Width="110"/>
                        <Button Name="SpecEditBtn" Classes="secondary" Content="Изменить" Width="110"/>
                        <Button Name="SpecDeleteBtn" Classes="danger" Content="Удалить" Width="100"/>
                    </StackPanel>
                    <DataGrid Grid.Row="1" Name="SpecsGrid" Classes="AppDataGrid" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
