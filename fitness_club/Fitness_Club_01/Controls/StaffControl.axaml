<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Fitness_Club_01.Controls.StaffControl">

    <Grid RowDefinitions="Auto,Auto,*,Auto">
        <TextBlock Grid.Row="0" Text="Сотрудники" FontSize="24" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,16"/>

        <Border Grid.Row="1" Background="White" CornerRadius="14" Padding="16" Margin="0,0,0,12"
                BorderBrush="#E2E8F0" BorderThickness="1">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Name="AddButton" Classes="primary" Content="Добавить" Width="120"/>
                <Button Name="EditButton" Classes="secondary" Content="Изменить" Width="120"/>
                <Button Name="AccountButton" Classes="secondary" Content="Выдать логин" Width="130"/>
                <Button Name="DeleteButton" Classes="danger" Content="Удалить" Width="110"/>
                <Button Name="RefreshButton" Classes="secondary" Content="Обновить" Width="110"/>
            </StackPanel>
        </Border>

        <DataGrid Grid.Row="2" Name="StaffGrid" Classes="AppDataGrid" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="№" Binding="{Binding Number}" Width="50"/>
                <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="220"/>
                <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="130"/>
                <DataGridTextColumn Header="Принят" Binding="{Binding HiredAtText}" Width="110"/>
                <DataGridTextColumn Header="Роль" Binding="{Binding RoleName}" Width="130"/>
                <DataGridTextColumn Header="Аккаунт" Binding="{Binding HasAccount}" Width="90"/>
                <DataGridTextColumn Header="Логин" Binding="{Binding Login}" Width="*" MinWidth="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="3" Name="StatusText" Margin="0,10,0,0" Foreground="#64748B" FontSize="12"/>
    </Grid>
</UserControl>
