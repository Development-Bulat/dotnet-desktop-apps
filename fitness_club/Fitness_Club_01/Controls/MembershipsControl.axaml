<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Fitness_Club_01.Controls.MembershipsControl">

    <Grid RowDefinitions="Auto,Auto,*,Auto">
        <TextBlock Grid.Row="0" Name="HeaderText" Text="Абонементы" FontSize="24" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,16"/>

        <Border Grid.Row="1" Background="White" CornerRadius="14" Padding="16" Margin="0,0,0,12"
                BorderBrush="#E2E8F0" BorderThickness="1">
            <Grid ColumnDefinitions="*,160,Auto,Auto,Auto" VerticalAlignment="Center">
                <TextBox Grid.Column="0" Name="SearchBox" Classes="modern" Watermark="Поиск по клиенту или тарифу..."/>
                <ComboBox Grid.Column="1" Name="StatusFilter" Margin="12,0,0,0" PlaceholderText="Статус"/>
                <Button Grid.Column="2" Name="AddButton" Classes="primary" Content="Оформить" Margin="12,0,0,0" MinWidth="120"/>
                <Button Grid.Column="3" Name="StatusButton" Classes="secondary" Content="Статус" Margin="8,0,0,0" Width="100"/>
                <Button Grid.Column="4" Name="RefreshButton" Classes="secondary" Content="Обновить" Margin="8,0,0,0" Width="110"/>
            </Grid>
        </Border>

        <DataGrid Grid.Row="2" Name="MembershipsGrid" Classes="AppDataGrid"
                  AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="№" Binding="{Binding Number}" Width="60"/>
                <DataGridTextColumn Header="Клиент" Binding="{Binding ClientName}" Width="200"/>
                <DataGridTextColumn Header="Тариф" Binding="{Binding TypeName}" Width="160"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding StatusName}" Width="120"/>
                <DataGridTextColumn Header="Период" Binding="{Binding Period}" Width="180"/>
                <DataGridTextColumn Header="Цена" Binding="{Binding Price}" Width="*" MinWidth="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="3" Name="StatusText" Margin="0,10,0,0" Foreground="#64748B" FontSize="12"/>
    </Grid>
</UserControl>
