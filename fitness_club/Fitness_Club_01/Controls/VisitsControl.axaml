<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Fitness_Club_01.Controls.VisitsControl">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
            <TextBlock Grid.Row="0" Text="Визиты" FontSize="24" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,16"/>

            <Border Grid.Row="1" Background="White" CornerRadius="14" Padding="16" Margin="0,0,0,12"
                    BorderBrush="#E2E8F0" BorderThickness="1">
                <Grid ColumnDefinitions="Auto,Auto,*,Auto" VerticalAlignment="Center">
                    <TextBlock Grid.Column="0" Text="Дата:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#64748B"/>
                    <CalendarDatePicker Grid.Column="1" Name="DayDatePicker" Classes="visitDate" MinWidth="260" Width="260"/>
                    <TextBlock Grid.Column="2" Name="OccupancyText" VerticalAlignment="Center" Margin="16,0,0,0"
                               Foreground="#0F172A" FontWeight="SemiBold" TextWrapping="Wrap"/>
                    <Button Grid.Column="3" Name="RefreshButton" Classes="secondary" Content="Обновить"
                            Margin="8,0,0,0" Width="110"/>
                </Grid>
            </Border>

            <TextBlock Grid.Row="2" Text="Записи на занятия" FontSize="14" FontWeight="SemiBold"
                       Foreground="#334155" Margin="0,0,0,8"/>

            <Grid Grid.Row="3" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                <TextBlock VerticalAlignment="Center" Foreground="#64748B" FontSize="12"
                           Text="Клиенты, записанные на групповые занятия в выбранный день"/>
                <Button Grid.Column="1" Name="MarkClassArrivalButton" Classes="primary" Content="Отметить приход на занятие"
                        MinWidth="200" IsVisible="False"/>
            </Grid>

            <DataGrid Grid.Row="4" Name="ExpectedGrid" Classes="AppDataGrid"
                      AutoGenerateColumns="False" IsReadOnly="True" MaxHeight="200" Margin="0,0,0,12">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="№" Binding="{Binding Number}" Width="50"/>
                    <DataGridTextColumn Header="Клиент" Binding="{Binding ClientName}" Width="200"/>
                    <DataGridTextColumn Header="Занятие" Binding="{Binding ClassName}" Width="160"/>
                    <DataGridTextColumn Header="Время" Binding="{Binding ClassTime}" Width="70"/>
                    <DataGridTextColumn Header="Зал" Binding="{Binding HallName}" Width="140"/>
                    <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="*" MinWidth="120"/>
                </DataGrid.Columns>
            </DataGrid>

            <TextBlock Grid.Row="5" Text="Посещение тренажёрного зала" FontSize="14" FontWeight="SemiBold"
                       Foreground="#334155" Margin="0,4,0,8"/>

            <Grid Grid.Row="6" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                <TextBlock VerticalAlignment="Center" Foreground="#64748B" FontSize="12"
                           Text="Клиенты с действующим абонементом без записи на занятие в этот день"/>
                <Button Grid.Column="1" Name="MarkGymArrivalButton" Classes="primary" Content="Отметить вход в зал"
                        MinWidth="180" IsVisible="False"/>
            </Grid>

            <DataGrid Grid.Row="7" Name="GymExpectedGrid" Classes="AppDataGrid"
                      AutoGenerateColumns="False" IsReadOnly="True" MaxHeight="200" Margin="0,0,0,12">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="№" Binding="{Binding Number}" Width="50"/>
                    <DataGridTextColumn Header="Клиент" Binding="{Binding ClientName}" Width="220"/>
                    <DataGridTextColumn Header="Абонемент" Binding="{Binding MembershipType}" Width="180"/>
                    <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="*" MinWidth="120"/>
                </DataGrid.Columns>
            </DataGrid>

            <TextBlock Grid.Row="8" Text="Отмеченные визиты за день" FontSize="14" FontWeight="SemiBold"
                       Foreground="#334155" Margin="0,4,0,8"/>

            <Border Grid.Row="9" Background="White" CornerRadius="14" Padding="16" Margin="0,0,0,12"
                    BorderBrush="#E2E8F0" BorderThickness="1">
                <TextBox Name="SearchBox" Classes="modern" Watermark="Поиск по клиенту..."/>
            </Border>

            <DataGrid Grid.Row="10" Name="VisitsGrid" Classes="AppDataGrid"
                      AutoGenerateColumns="False" IsReadOnly="True" MinHeight="160">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="№" Binding="{Binding Number}" Width="50"/>
                    <DataGridTextColumn Header="Клиент" Binding="{Binding ClientName}" Width="200"/>
                    <DataGridTextColumn Header="Тип" Binding="{Binding VisitType}" Width="160"/>
                    <DataGridTextColumn Header="Время входа" Binding="{Binding VisitDateTime}" Width="130"/>
                    <DataGridTextColumn Header="Отметил" Binding="{Binding MarkedBy}" Width="140"/>
                    <DataGridTextColumn Header="Абонемент" Binding="{Binding MembershipType}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>

            <TextBlock Grid.Row="11" Name="StatusText" Margin="0,10,0,0" Foreground="#64748B" FontSize="12"/>
        </Grid>
    </ScrollViewer>
</UserControl>
