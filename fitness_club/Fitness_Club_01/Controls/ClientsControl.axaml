<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Fitness_Club_01.Controls.ClientsControl">

    <Grid RowDefinitions="Auto,Auto,*,Auto">
        <TextBlock Grid.Row="0" Text="Клиенты" FontSize="24" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,16"/>

        <Border Grid.Row="1" Background="White" CornerRadius="14" Padding="16" Margin="0,0,0,12"
                BorderBrush="#E2E8F0" BorderThickness="1">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto" VerticalAlignment="Center">
                <TextBox Grid.Column="0" Name="SearchBox" Classes="modern" Watermark="Поиск по ФИО или телефону..."/>
                <Button Grid.Column="1" Name="AddButton" Classes="primary" Content="Добавить" Margin="12,0,0,0" Width="120"/>
                <Button Grid.Column="2" Name="EditButton" Classes="secondary" Content="Изменить" Margin="8,0,0,0" Width="120"/>
                <Button Grid.Column="3" Name="AccountButton" Classes="secondary" Content="Выдать логин" Margin="8,0,0,0" Width="130"/>
                <Button Grid.Column="4" Name="DeleteButton" Classes="danger" Content="Удалить" Margin="8,0,0,0" Width="110"/>
                <Button Grid.Column="5" Name="RefreshButton" Classes="secondary" Content="Обновить" Margin="8,0,0,0" Width="110"/>
            </Grid>
        </Border>

        <DataGrid Grid.Row="2" Name="ClientsGrid" Classes="AppDataGrid"
                  AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="№" Binding="{Binding Number}" Width="60"/>
                <DataGridTextColumn Header="Фамилия" Binding="{Binding LastName}" Width="130"/>
                <DataGridTextColumn Header="Имя" Binding="{Binding FirstName}" Width="120"/>
                <DataGridTextColumn Header="Отчество" Binding="{Binding Patronymic}" Width="130"/>
                <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="140"/>
                <DataGridTextColumn Header="Дата рождения" Binding="{Binding BirthDateText}" Width="120"/>
                <DataGridTextColumn Header="Аккаунт" Binding="{Binding HasAccount}" Width="90"/>
                <DataGridTextColumn Header="Логин" Binding="{Binding Login}" Width="*" MinWidth="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="3" Name="StatusText" Margin="0,10,0,0" Foreground="#64748B" FontSize="12"/>
    </Grid>
</UserControl>
