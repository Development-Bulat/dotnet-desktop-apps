<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Fitness_Club_01.Views.StaffAccountWindow"
        Title="Учётная запись сотрудника"
        Width="440" Height="400"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="#F8FAFC">

    <Border Background="White" Margin="16" CornerRadius="14" Padding="24" BorderBrush="#E2E8F0" BorderThickness="1">
        <Grid RowDefinitions="*,Auto,Auto">
            <StackPanel Grid.Row="0" Spacing="12">
                <TextBlock Name="StaffNameText" FontSize="18" FontWeight="Bold" Foreground="#0F172A"/>
                <ComboBox Name="RoleCombo" PlaceholderText="Роль *"/>
                <TextBox Name="LoginBox" Classes="modern" Watermark="Логин *" MaxLength="50"/>
                <TextBox Name="PasswordBox" Classes="modern" Watermark="Пароль *" PasswordChar="•" MaxLength="16"/>
            </StackPanel>
            <TextBlock Grid.Row="1" Name="ErrorText" Foreground="#EF4444" FontSize="12" TextWrapping="Wrap" Margin="0,8,0,0"/>
            <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto" Margin="0,12,0,0">
                <Button Grid.Column="1" Name="CancelButton" Classes="secondary dialog" Content="Отмена"/>
                <Button Grid.Column="2" Name="SaveButton" Classes="primary dialog" Content="Создать" Margin="10,0,0,0"/>
            </Grid>
        </Grid>
    </Border>
</Window>
