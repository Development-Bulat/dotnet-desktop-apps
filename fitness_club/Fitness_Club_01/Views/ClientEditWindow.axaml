<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Fitness_Club_01.Views.ClientEditWindow"
        Title="Клиент"
        Width="480" Height="520"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="#F8FAFC">

    <Border Background="White" Margin="16" CornerRadius="14" Padding="24" BorderBrush="#E2E8F0" BorderThickness="1">
        <Grid RowDefinitions="*,Auto,Auto">
            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="12">
                    <TextBlock Name="TitleText" Text="Новый клиент" FontSize="20" FontWeight="Bold" Foreground="#0F172A"/>
                    <TextBox Name="LastNameBox" Classes="modern" Watermark="Фамилия *" MaxLength="100"/>
                    <TextBox Name="FirstNameBox" Classes="modern" Watermark="Имя *" MaxLength="100"/>
                    <TextBox Name="PatronymicBox" Classes="modern" Watermark="Отчество" MaxLength="100"/>
                    <TextBlock Text="Телефон *" FontSize="13" Foreground="#64748B"/>
                    <TextBox Name="PhoneBox" Classes="modern" MaxLength="18"/>
                    <DatePicker Name="BirthDatePicker"/>
                </StackPanel>
            </ScrollViewer>

            <TextBlock Grid.Row="1" Name="ErrorText" Foreground="#EF4444" FontSize="12" TextWrapping="Wrap" Margin="0,8,0,0"/>

            <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto" Margin="0,12,0,0">
                <Button Grid.Column="1" Name="CancelButton" Classes="secondary dialog" Content="Отмена"/>
                <Button Grid.Column="2" Name="SaveButton" Classes="primary dialog" Content="Сохранить" Margin="10,0,0,0"/>
            </Grid>
        </Grid>
    </Border>
</Window>
