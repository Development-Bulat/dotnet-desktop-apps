<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Fitness_Club_01.Views.ReferenceEditWindow"
        Title="Справочник"
        Width="440" Height="420"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="#F8FAFC">

    <Border Background="White" Margin="16" CornerRadius="14" Padding="24" BorderBrush="#E2E8F0" BorderThickness="1">
        <Grid RowDefinitions="*,Auto,Auto">
            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="12">
                    <TextBlock Name="TitleText" FontSize="20" FontWeight="Bold" Foreground="#0F172A"/>
                    <TextBox Name="NameBox" Classes="modern" Watermark="Название *" MaxLength="150"/>
                    <TextBox Name="PriceBox" Classes="modern" Watermark="Цена" MaxLength="10"/>
                    <TextBox Name="DurationBox" Classes="modern" Watermark="Дней" MaxLength="4"/>
                    <TextBox Name="VisitLimitBox" Classes="modern" Watermark="Лимит визитов (пусто = безлимит)" MaxLength="4"/>
                    <TextBox Name="CapacityBox" Classes="modern" Watermark="Вместимость зала" MaxLength="4"/>
                </StackPanel>
            </ScrollViewer>
            <TextBlock Grid.Row="1" Name="ErrorText" Foreground="#EF4444" FontSize="12" TextWrapping="Wrap" Margin="0,8,0,0"/>
            <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto" Margin="0,12,0,0">
                <Button Grid.Column="1" Name="CancelButton" Classes="secondary dialog" Content="Отмена"/>
                <Button Grid.Column="2" Name="SaveButton" Classes="primary dialog" Content="Сохранить" Margin="10,0,0,0"/>
            </Grid>
        </Grid>
    </Border>
</Window>
