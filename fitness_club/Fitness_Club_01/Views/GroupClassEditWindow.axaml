<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Fitness_Club_01.Views.GroupClassEditWindow"
        Title="Занятие"
        Width="500" Height="600"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="#F8FAFC">

    <Border Background="White" Margin="16" CornerRadius="14" Padding="24" BorderBrush="#E2E8F0" BorderThickness="1">
        <Grid RowDefinitions="*,Auto,Auto">
            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="10">
                    <TextBlock Name="TitleText" Text="Новое занятие" FontSize="20" FontWeight="Bold" Foreground="#0F172A"/>
                    <TextBox Name="ClassNameBox" Classes="modern" Watermark="Название *" MaxLength="150"/>
                    <ComboBox Name="HallCombo" PlaceholderText="Зал *"/>
                    <ComboBox Name="TrainerCombo" PlaceholderText="Тренер *"/>
                    <ComboBox Name="DayCombo" PlaceholderText="День недели *"/>
                    <TextBox Name="StartTimeBox" Classes="modern" Watermark="Время начала (ЧЧ:ММ) *" MaxLength="5"/>
                    <TextBox Name="DurationBox" Classes="modern" Watermark="Длительность (мин) *" MaxLength="3"/>
                    <TextBox Name="MaxParticipantsBox" Classes="modern" Watermark="Макс. участников *" MaxLength="3"/>
                    <CheckBox Name="IsActiveCheck" Content="Активно" IsChecked="True"/>
                </StackPanel>
            </ScrollViewer>
            <TextBlock Grid.Row="1" Name="ErrorText" Foreground="#EF4444" FontSize="12" TextWrapping="Wrap" Margin="0,8,0,0"/>
            <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto" Margin="0,12,0,0">
                <Button Grid.Column="1" Name="CancelButton" Classes="secondary dialog" Content="Отмена"/>
                <Button Grid.Column="2" Name="SaveButton" Classes="primary dialog" Content="Сохранить" Margin="10,0,0,0"/>
            </Grid>
        </Grid>
    </Border>
</Window>
